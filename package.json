{
  "name": "@rozsival/panther-minor-controller",
  "version": "1.0.6",
  "private": true,
  "description": "Remote controller for Panther Minor AI workstation",
  "repository": {
    "type": "git",
    "url": "https://github.com/rozsival/panther-minor-controller.git"
  },
  "license": "MIT",
  "type": "module",
  "scripts": {
    "cargo:build": "cargo build --workspace",
    "cargo:check": "cargo check --workspace",
    "cargo:clippy": "cargo clippy --workspace -- -D warnings",
    "cargo:fmt": "cargo fmt",
    "cargo:run": "cargo watch -x run",
    "cargo:test": "cargo test --workspace",
    "postinstall": "is-ci || lefthook install",
    "prettier:write": "prettier --check --write ."
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@types/node": "24.13.2",
    "is-ci": "4.1.0",
    "lefthook": "2.1.9",
    "prettier": "3.8.4",
    "prettier-plugin-packagejson": "3.0.2",
    "prettier-plugin-toml": "2.0.6",
    "typescript": "6.0.3"
  },
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": "24.x"
  }
}
